{
  "_comment": "Retro-SFX-first default. BGM still swaps between 'village' (idle) and 'quest' (working), but work now gets a short 8-bit submit chirp plus a repeating processing pulse. Set pulse to '__stop' to halt the loop. Override at %LOCALAPPDATA%/cc-bgm/triggermap.json.",

  "SessionStart": { "bgm": "village", "sfx": "fanfare_soft" },
  "UserPromptSubmit": { "bgm": "quest", "sfx": "submit", "pulse": "progress" },

  "PreToolUse": {
    "_byTool": {
      "Read": {},
      "Bash": { "bgm": "quest", "pulse": "progress" },
      "Edit": { "bgm": "quest", "pulse": "progress" },
      "Write": { "bgm": "quest", "pulse": "progress" },
      "_default": { "bgm": "quest", "pulse": "progress" }
    }
  },

  "PostToolUse": {
    "_byTool": {
      "Edit": { "sfx": "save" },
      "Write": { "sfx": "save" },
      "_default": {}
    }
  },

  "PostToolUseFailure": { "sfx": "error" },

  "SubagentStart": { "bgm": "quest" },
  "SubagentStop": {},

  "Notification": {
    "_byType": {
      "permission_prompt": { "sfx": "summon" },
      "idle_prompt": { "bgm": "village", "pulse": "__stop" }
    }
  },

  "Stop": { "bgm": "village", "pulse": "__stop", "sfx": "questclear" },
  "SessionEnd": { "bgm": "__stop", "pulse": "__stop" }
}
